#!/usr/bin/env bash
# Hit the API lockfile endpoints with curl.
#
# Usage:
#   bin/api_check_lockfile <Gemfile.lock>          # stream SSE events as gem_checks resolve
#   bin/api_check_lockfile <Gemfile.lock> --json   # old mode: returns { "slug": "..." }
#   bin/api_check_lockfile --show <slug>           # GET /lockfiles/:slug as JSON
#
# Override host with API_HOST (default: api.localhost:3000):
#   API_HOST=api.railsbump.org bin/api_check_lockfile Gemfile.lock

set -euo pipefail

HOST="${API_HOST:-api.localhost:3000}"
SCHEME="${API_SCHEME:-http}"
BASE="${SCHEME}://${HOST}"

usage() {
  sed -n '2,/^$/p' "$0" >&2
  exit 1
}

[[ $# -ge 1 ]] || usage

if [[ "$1" == "--show" ]]; then
  [[ $# -eq 2 ]] || usage
  curl -sS "${BASE}/lockfiles/$2" | jq .
  exit 0
fi

LOCKFILE="$1"
MODE="${2:-stream}"

[[ -f "$LOCKFILE" ]] || { echo "Not a file: $LOCKFILE" >&2; exit 1; }
command -v jq >/dev/null || { echo "jq required" >&2; exit 1; }

BODY="$(jq -Rs '{lockfile: {content: .}}' < "$LOCKFILE")"

case "$MODE" in
  stream)
    exec curl -sS -N -X POST "${BASE}/lockfiles" \
      -H 'Content-Type: application/json' \
      -H 'Accept: text/event-stream' \
      --data-binary "$BODY"
    ;;
  --json|json)
    curl -sS -X POST "${BASE}/lockfiles" \
      -H 'Content-Type: application/json' \
      --data-binary "$BODY" | jq .
    ;;
  *)
    usage
    ;;
esac
